# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side only — used by API routes (e.g. /api/leads). NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Used by `pnpm gen:types` to regenerate src/types/database.ts from your live schema.
# Find this in: Supabase Dashboard → Project Settings → General → Reference ID
SUPABASE_PROJECT_ID=your-project-ref-id

# ── Stripe ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Configure Stripe webhook endpoint to: https://<your-domain>/api/webhooks/stripe
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_ELITE=price_...

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://trades-canada.com

# ── AI Lead Qualification (optional — falls back to heuristic if missing) ──────
# Uses gpt-4o-mini via Chat Completions API with JSON mode
OPENAI_API_KEY=sk-...

# ── Meta Pixel / CAPI (optional — analytics only) ─────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id
META_CAPI_ACCESS_TOKEN=your-capi-token
# META_CAPI_TEST_CODE is for testing ONLY — do NOT set this in production
# META_CAPI_TEST_CODE=TEST12345
