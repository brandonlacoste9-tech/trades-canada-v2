SUPABASE_ENABLE_LEGACY_STRIPE_WEBHOOK=false

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token

# ── Firecrawl ─────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=your-firecrawl-key

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-key

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_URL=https://trades-canada.com
