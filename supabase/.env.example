# ── Supabase (auto-injected in Edge Functions, include for local dev) ──────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# ⚠️  Keep FALSE — primary webhook is apps/web/src/app/api/webhooks/stripe/route.ts
SUPABASE_ENABLE_LEGACY_STRIPE_WEBHOOK=false

# ── Firecrawl (permit scraping) ───────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...

# ── Google Maps (permit geocoding in firecrawl-scrape-permits) ────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ── Resend (email queue) ──────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Telegram (lead alerts) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-...
