{
  "name": "trades-canada",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "dependencies": {
    "next": "^15.3.1"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @trades-canada/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "validate:ops": "node ./scripts/validate-ops.mjs",
    "check": "pnpm type-check && pnpm --filter @trades-canada/web lint",
    "check:web": "pnpm --filter @trades-canada/web type-check && pnpm --filter @trades-canada/web lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.0.0"
}
