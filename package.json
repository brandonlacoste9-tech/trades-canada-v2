{
  "name": "trades-canada",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "next": "^15.5.14"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @trades-canada/web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "gen:types": "pnpm --filter @trades-canada/web gen:types",
    "validate:ops": "node ./scripts/validate-ops.mjs",
    "check": "pnpm type-check && pnpm --filter @trades-canada/web lint",
    "check:web": "pnpm --filter @trades-canada/web type-check && pnpm --filter @trades-canada/web lint"
  },
  "devDependencies": {
    "turbo": "^2.8.21",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "brace-expansion@>=2.0.0 <=2.0.1": "2.0.2",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5"
    }
  }
}
